# Public community bot token — NEVER reuse ARMARAOS daemon token
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Optional: staff role IDs (comma-separated) for mod commands
STAFF_ROLE_IDS=

# Product feeds (no auth required today)
NOTIFICATIONS_URL=https://www.ainativelang.com/notifications
DOCS_SEARCH_URL=https://www.ainativelang.com/api/docs/search
BLOG_FEED_URL=https://www.ainativelang.com/blog/feed.json

# Optional ArmaraOS bridge (staff support channel only; loopback default)
ARMARAOS_API_BASE=http://127.0.0.1:4200
ARMARAOS_API_KEY=

# Optional LLM for FAQ / triage (OpenRouter, Groq, etc.)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=

AINL_VALIDATE_URL=http://127.0.0.1:8765/validate
DOCS_MANIFEST_URL=https://www.ainativelang.com/search/docs-manifest.json
DATABASE_PATH=./data/bot.db
CONFIG_PATH=./config/default.json
