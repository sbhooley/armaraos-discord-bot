{
  "name": "armaraos-discord-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Community Discord bot for ArmaraOS / AINL — moderation, support, product-aware FAQ",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "register-commands": "tsx scripts/register-commands.ts",
    "setup": "node scripts/setup.mjs"
  },
  "keywords": ["discord", "armaraos", "ainl", "community"],
  "license": "MIT",
  "dependencies": {
    "@sapphire/decorators": "^6.1.1",
    "@sapphire/framework": "^5.5.0",
    "@sapphire/plugin-logger": "^4.0.2",
    "better-sqlite3": "^11.10.0",
    "discord.js": "^14.22.1",
    "dotenv": "^16.6.1",
    "node-cron": "^4.2.1",
    "yaml": "^2.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
